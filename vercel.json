{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "medaffairs-ai-poc",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "sujeet/poc/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.py" }
  ]
}
