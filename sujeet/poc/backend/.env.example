# Medical Affairs AI POC — API keys
# Copy to .env and fill in your keys:
#   cp .env.example .env
#
# Get a free NCBI API key: https://www.ncbi.nlm.nih.gov/account/settings/
PUBMED_API_KEY=

# Optional — enables GPT-4o-mini for SLR screening & extraction.
# Without this key, the agent uses rule-based fallbacks (still works for demo).
OPENAI_API_KEY=
